  const seven = last7(e); const max = Math.max(1, ...seven.map(d=>d.total));

  // bolinhas de constância (últimos 7 dias)
  const dotDays = [];
  for (let i=6;i>=0;i--){ const key = isoDaysAgo(i); const d = new Date(); d.setDate(d.getDate()-i);
    dotDays.push({ on: e.some(x=>x.date.slice(0,10)===key), today: i===0, wd: ["D","S","T","Q","Q","S","S"][d.getDay()] }); }

  let suggestion = "Seu desempenho está equilibrado. Mantenha a constância e aumente o volume aos poucos.";
