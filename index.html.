      </div>` : ""}
      ${totGoal>0 ? `<div class="${hGoal>0?'mt16':''}">
        <div class="row between" style="margin-bottom:6px"><span style="font-weight:600;font-size:14px">Banco total</span><span class="muted">${totalHours}h / ${totGoal}h</span></div>
        <div class="bar" style="height:12px"><span style="width:${totPct}%;background:${totPct>=100?'var(--success)':'var(--primary)'}"></span></div>
        <p style="margin:6px 0 0;font-weight:700;color:${totPct>=100?'var(--success)':'var(--muted)'}">${totPct}%${totPct>=100?" — banco batido! 🎉":""}</p>
      </div>` : ""}
    </div>` : `<div class="empty mt12"><div class="big">🎯</div><h3>Defina suas metas de tempo</h3><p>Preencha os campos acima para acompanhar o progresso.</p></div>`}

    <div class="section-title">Horas nos últimos 7 dias</div>
    <div class="card">
      ${totalMin>0 ? `<div class="chart">${seven.map(d=>`<div class="col"><div class="cval">${d.min?(Math.round(d.min/60*10)/10)+"h":""}</div>
        <div class="stick" style="height:${d.min?Math.max(4,Math.round(d.min/maxDay*100)):1}%;background:linear-gradient(180deg,var(--info),var(--primary))"></div>
        <div class="clabel">${d.label}</div></div>`).join("")}</div>`
        : `<p class="li-meta" style="margin:0">Registre questões com o campo <b>Tempo (min)</b> preenchido para ver o gráfico.</p>`}
    </div>

    <div class="section-title">Horas por matéria</div>
    <div class="card">
      ${timeRows.length ? timeRows.map(r=>`<div style="margin:10px 0">
        <div class="row between" style="margin-bottom:6px"><span style="font-weight:600;font-size:14px">${r.name}</span>
        <span class="li-meta" style="margin:0;font-weight:700;color:var(--text)">${fmtMin(r.min)}</span></div>
        <div class="bar"><span style="width:${Math.max(3,Math.round(r.min/maxMin*100))}%;background:var(--info)"></span></div>
      </div>`).join("") : `<p class="li-meta" style="margin:0">Preencha o campo <b>Tempo (min)</b> ao registrar questões para acompanhar suas horas por matéria.</p>`}
    </div>`;
}

/* ---- Metas ---- */
function viewMetas() {
  const week = state.entries.filter(x=>isThisWeek(x.date));
  const done = week.reduce((s,x)=>s+(+x.total),0);
  const goal = +state.weeklyGoal||0;
  const pct = goal>0 ? Math.min(100, Math.round(done/goal*100)) : 0;
  return `<h1 class="page">Metas</h1><p class="sub">Defina seu alvo semanal de questões. As metas de tempo ficam na aba Horas.</p>
    <div class="card">
      <label class="field">Meta de questões por semana</label>
      <div class="row" style="gap:10px">
        <input class="input" type="number" inputmode="numeric" id="m_goal" min="0" value="${goal||""}" placeholder="Ex.: 300">
        <button class="btn btn-primary" onclick="saveGoal()">Salvar</button>
      </div>
    </div>
    ${goal>0 ? `<div class="card mt12">
      <div class="row between" style="margin-bottom:8px"><b>Progresso da semana</b><span class="muted">${done} / ${goal}</span></div>
      <div class="bar" style="height:12px"><span style="width:${pct}%;background:${pct>=100?'var(--success)':'var(--primary)'}"></span></div>
      <p class="${pct>=100?'':'muted'}" style="margin:10px 0 0;font-weight:700;color:${pct>=100?'var(--success)':'var(--muted)'}">${pct}%${pct>=100?" — meta batida! 🎉":""}</p>
    </div>` : `<div class="empty mt12"><div class="big">🎯</div><h3>Sem meta definida</h3><p>Defina um valor acima para acompanhar seu progresso.</p></div>`}

    <div class="section-title">Backup e dados</div>
    <div class="card">
      <p class="li-meta" style="margin-top:0">Seus dados ficam neste dispositivo. Faça backup de vez em quando para não perder nada.</p>
      <button class="btn btn-primary btn-block" onclick="downloadJSON()">⬇️ Baixar backup (.json)</button>
      <div class="mt12"></div>
      <button class="btn btn-ghost btn-block" onclick="copyJSON()">📋 Copiar backup (JSON)</button>

      <label class="field mt16">Restaurar a partir de um backup</label>
      <input type="file" id="impFile" accept=".json,application/json" class="hidden" onchange="onImportFile(event)">
      <button class="btn btn-ghost btn-block" onclick="document.getElementById('impFile').click()">📁 Escolher arquivo .json</button>
      <div class="mt12"></div>
      <textarea id="impText" placeholder="…ou cole aqui o conteúdo do backup e toque em Importar"></textarea>
      <div class="mt8"></div>
      <button class="btn btn-ghost btn-block" onclick="importPaste()">Importar texto colado</button>
    </div>

    <div class="card danger-zone mt12">
      <button class="btn btn-ghost btn-block" onclick="exportData()">Exportar resumo (texto)</button>
      <div class="mt12"></div>
      <button class="btn btn-danger btn-block" onclick="resetAll()">Apagar todos os dados</button>
    </div>`;
}

/* --------------------------- ações / handlers ------------------------------ */
function calcWrong() {
  const t = +(document.getElementById("q_total")||{}).value || 0;
  const c = +(document.getElementById("q_correct")||{}).value || 0;
  const el = document.getElementById("q_wrong"); if (el) el.value = Math.max(0, t - c);
}
window.calcWrong = calcWrong;

function wireSubjectArea() {
  const subj = document.getElementById("q_subject");
  if (subj) subj.addEventListener("change", () => {
    const s = SUBJECTS.find(x=>x.v===subj.value); const area = document.getElementById("q_area");
    if (s && area && !area.value) area.value = s.a;
  });
}

async function addEntry() {
  const g = id => (document.getElementById(id)||{}).value;
  const total = parseInt(g("q_total"),10), correct = parseInt(g("q_correct"),10);
  const subject = g("q_subject"), area = g("q_area") || (SUBJECTS.find(s=>s.v===subject)||{}).a;
  if (!subject) return toast("Selecione a matéria");
  if (!Number.isFinite(total) || total <= 0) return toast("Informe a quantidade de questões");
  if (!Number.isFinite(correct) || correct < 0) return toast("Informe os acertos");
  if (correct > total) return toast("Acertos não podem passar do total");
  const data = { date: g("q_date")||todayISO(), area: area||"linguagens", subject,
    topic: (g("q_topic")||"").trim(), source: g("q_source")||"", total, correct,
    minutes: parseInt(g("q_min"),10)||0, difficulty: g("q_diff")||"" };
  if (editEntryId) {
    const i = state.entries.findIndex(e=>e.id===editEntryId);
    if (i>=0) state.entries[i] = Object.assign({}, state.entries[i], data);
    editEntryId = null; await persist(); render(); toast("Registro atualizado!");
  } else {
    state.entries.push(Object.assign({ id: uid() }, data)); await persist(); render(); toast("Questões registradas!"); maybeRemindBackup();
  }
}
window.addEntry = addEntry;
function editEntry(id){ editEntryId = id; render(); window.scrollTo({top:0,behavior:"smooth"}); }
window.editEntry = editEntry;
function cancelEdit(){ editEntryId = null; render(); }
window.cancelEdit = cancelEdit;
async function delEntry(id) {
  const idx = state.entries.findIndex(e=>e.id===id); if (idx<0) return;
  const removed = state.entries[idx];
  state.entries.splice(idx,1); if (editEntryId===id) editEntryId=null;
  await persist(); render();
  toast("Registro excluído", "Desfazer", async () => {
    state.entries.splice(Math.min(idx, state.entries.length), 0, removed); await persist(); render();
  });
}
window.delEntry = delEntry;

function calcEssayTotal() {
  let s = 0; for (let i=1;i<=5;i++){ s += +((document.getElementById("r_c"+i)||{}).value||0); }
  const el = document.getElementById("r_total_lbl"); if (el) el.textContent = s;
}
window.calcEssayTotal = calcEssayTotal;

async function addEssay() {
  const g = id => (document.getElementById(id)||{}).value;
  const theme = (g("r_theme")||"").trim();
  if (!theme) return toast("Informe o tema da redação");
  const comps = {}; let total = 0; let any = false;
  for (let i=1;i<=5;i++){ const v = g("r_c"+i); if (v!==""&&v!=null){ comps["c"+i]=Math.max(0,Math.min(200,parseInt(v,10)||0)); total+=comps["c"+i]; any=true; } else comps["c"+i]=null; }
  const data = Object.assign({ date: g("r_date")||todayISO(), theme, total: any?total:null }, comps);
  if (editEssayId) {
    const i = state.essays.findIndex(e=>e.id===editEssayId);
    if (i>=0) state.essays[i] = Object.assign({}, state.essays[i], data);
    editEssayId = null; await persist(); render(); toast("Redação atualizada!");
  } else {
    state.essays.push(Object.assign({ id: uid() }, data)); await persist(); render(); toast("Redação registrada!"); maybeRemindBackup();
  }
}
window.addEssay = addEssay;
function editEssay(id){ editEssayId = id; render(); window.scrollTo({top:0,behavior:"smooth"}); }
window.editEssay = editEssay;
function cancelEditEssay(){ editEssayId = null; render(); }
window.cancelEditEssay = cancelEditEssay;
async function delEssay(id) {
  const idx = state.essays.findIndex(e=>e.id===id); if (idx<0) return;
  const removed = state.essays[idx];
  state.essays.splice(idx,1); if (editEssayId===id) editEssayId=null;
  await persist(); render();
  toast("Redação excluída", "Desfazer", async () => {
    state.essays.splice(Math.min(idx, state.essays.length), 0, removed); await persist(); render();
  });
}
window.delEssay = delEssay;

async function saveGoal() {
  const q = parseInt((document.getElementById("m_goal")||{}).value,10);
  state.weeklyGoal = Number.isFinite(q) && q>0 ? q : 0;
  await persist(); toast("Meta salva!"); render();
}
window.saveGoal = saveGoal;

async function saveHoras() {
  const h = parseFloat((document.getElementById("h_week")||{}).value);
  const tg = parseInt((document.getElementById("h_total")||{}).value,10);
  state.weeklyHoursGoal = Number.isFinite(h) && h>0 ? Math.round(h*10)/10 : 0;
  state.totalHoursGoal = Number.isFinite(tg) && tg>0 ? tg : 0;
  await persist(); toast("Metas de tempo salvas!"); render();
}
window.saveHoras = saveHoras;

async function resetAll() {
  if (!confirm("Apagar TODOS os dados deste dispositivo? Dica: baixe um backup antes.")) return;
  const snapshot = JSON.parse(JSON.stringify(state));
  const theme = state.theme; state = defaults(); state.theme = theme;
  await persist(); render();
  toast("Tudo apagado", "Desfazer", async () => { state = snapshot; await persist(); applyTheme(); render(); });
}
window.resetAll = resetAll;

/* ----------------------------- backup / restore ---------------------------- */
function backupString(){ return JSON.stringify({ app:"enem-tracker", version:1, exportedAt:new Date().toISOString(),
  entries: state.entries, essays: state.essays, weeklyGoal: state.weeklyGoal,
  weeklyHoursGoal: state.weeklyHoursGoal, totalHoursGoal: state.totalHoursGoal }, null, 2); }

function downloadJSON() {
  const data = backupString();
  state.backupBase = state.entries.length + state.essays.length; persist();
  try {
    const blob = new Blob([data], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = "enem-tracker-backup.json";
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(()=>URL.revokeObjectURL(url), 1500);
    toast("Backup .json gerado. Se não baixar, use Copiar.");
  } catch(e) { fallbackCopy(data); }
}
window.downloadJSON = downloadJSON;
function copyJSON(){ state.backupBase = state.entries.length + state.essays.length; persist(); fallbackCopy(backupString()); }
window.copyJSON = copyJSON;

function maybeRemindBackup(){
  if (!hasStore) return;
  const n = state.entries.length + state.essays.length;
  if (n - (state.backupBase||0) >= 20){ state.backupBase = n; persist(); toast("Vários registros novos — que tal um backup?", "Baixar", downloadJSON); }
}

async function applyImport(text) {
  let obj;
  try { obj = JSON.parse(text); } catch(e) { return toast("Conteúdo inválido (não é JSON)"); }
  if (!obj || typeof obj !== "object" || !Array.isArray(obj.entries)) return toast("Backup não reconhecido");
  if (!confirm("Restaurar este backup vai SUBSTITUIR os dados atuais. Continuar?")) return;
  state = Object.assign(defaults(), {
    entries: Array.isArray(obj.entries) ? obj.entries.map(x=>Object.assign({id:uid()}, x)) : [],
    essays:  Array.isArray(obj.essays)  ? obj.essays.map(x=>Object.assign({id:uid()}, x))  : [],
    weeklyGoal: +obj.weeklyGoal || 0,
    weeklyHoursGoal: +obj.weeklyHoursGoal || 0,
    totalHoursGoal: +obj.totalHoursGoal || 0,
    theme: state.theme,
  });
  state.backupBase = state.entries.length + state.essays.length;
  await persist(); toast("Backup restaurado!"); render();
}
function onImportFile(ev) {
  const f = ev.target.files && ev.target.files[0]; if (!f) return;
  const r = new FileReader(); r.onload = () => applyImport(String(r.result)); r.onerror = () => toast("Não consegui ler o arquivo"); r.readAsText(f);
}
window.onImportFile = onImportFile;
function importPaste() {
  const t = (document.getElementById("impText")||{}).value || "";
  if (!t.trim()) return toast("Cole o conteúdo do backup primeiro");
  applyImport(t.trim());
}
window.importPaste = importPaste;

function exportData() {
  const lines = ["ENEM Tracker — resumo", "Gerado em " + new Date().toLocaleString("pt-BR"), "", "QUESTÕES:"];
  state.entries.forEach(e=>lines.push(`${fmtBR(e.date)} | ${SUBJ_NAME[e.subject]||e.subject} | ${e.correct}/${e.total} (${taxa(e.correct,e.total)}%) | ${fmtMin(e.minutes)}${e.source?" | "+(SOURCE_NAME[e.source]||e.source):""}${e.topic?" | "+e.topic:""}`));
  lines.push("", "REDAÇÕES:");
  state.essays.forEach(e=>lines.push(`${fmtBR(e.date)} | ${e.theme} | total ${e.total??"-"} | C ${[1,2,3,4,5].map(i=>e["c"+i]??"-").join("/")}`));
  const text = lines.join("\n");
  if (navigator.share) navigator.share({ title: "ENEM Tracker", text }).catch(()=>fallbackCopy(text));
  else fallbackCopy(text);
}
window.exportData = exportData;

function fallbackCopy(text) {
  if (navigator.clipboard && navigator.clipboard.writeText) navigator.clipboard.writeText(text).then(()=>toast("Copiado para a área de transferência")).catch(()=>showText(text));
  else showText(text);
}
function showText(text){ try { window.prompt("Copie o conteúdo abaixo:", text); } catch(e) { alert(text); } }

/* --------------------------- dados de exemplo ------------------------------ */
async function seedDemo() {
  const base = ["matematica","biologia","historia","portugues","fisica","geografia","quimica","ingles"];
  const rate = { matematica:.49, biologia:.81, historia:.7, portugues:.74, fisica:.55, geografia:.68, quimica:.58, ingles:.77 };
  const srcs = ["enem","simulado","apostila","plataforma","proprias"];
  const entries = [];
  for (let d=20; d>=0; d--) {
    if (Math.random() > 0.7) continue;
    const dt = new Date(); dt.setDate(dt.getDate()-d);
    const iso = new Date(dt.getTime()-dt.getTimezoneOffset()*60000).toISOString().slice(0,10);
    const n = 1 + Math.floor(Math.random()*2);
    for (let i=0;i<n;i++){ const subj = base[Math.floor(Math.random()*base.length)];
      const total = 8 + Math.floor(Math.random()*16);
      const r = Math.max(.2, Math.min(.97, (rate[subj]||.65) + (Math.random()-.5)*.18));
      entries.push({ id: uid(), date: iso, area:(SUBJECTS.find(s=>s.v===subj)||{}).a||"linguagens", subject: subj,
        topic:"", source: srcs[Math.floor(Math.random()*srcs.length)], total, correct: Math.round(total*r),
        minutes: 15+Math.floor(Math.random()*60), difficulty:"" }); }
  }
  const essays = [["Inclusão digital no Brasil",160,170,120,150,140],["Evasão escolar",150,160,140,160,130],["Saúde mental dos jovens",170,180,150,170,160]]
    .map((e,i)=>{ const dt=new Date(); dt.setDate(dt.getDate()-i*6-2);
      return { id: uid(), date:new Date(dt.getTime()-dt.getTimezoneOffset()*60000).toISOString().slice(0,10), theme:e[0],
        c1:e[1],c2:e[2],c3:e[3],c4:e[4],c5:e[5], total:e[1]+e[2]+e[3]+e[4]+e[5] }; });
  state.entries = entries.concat(state.entries);
  state.essays = essays.concat(state.essays);
  if (!state.weeklyGoal) state.weeklyGoal = 300;
  if (!state.weeklyHoursGoal) state.weeklyHoursGoal = 18;
  if (!state.totalHoursGoal) state.totalHoursGoal = 300;
  state.backupBase = state.entries.length + state.essays.length;
  await persist(); toast("Dados de exemplo carregados!"); render();
}
window.seedDemo = seedDemo;

/* ---------------------------------- tema ----------------------------------- */
function applyTheme() {
  const dark = state.theme === "dark";
  document.body.classList.toggle("dark", dark);
  const b = document.getElementById("themeBtn"); if (b) b.textContent = dark ? "☀️" : "🌙";
}
async function toggleTheme() {
  state.theme = document.body.classList.contains("dark") ? "light" : "dark";
  applyTheme(); await persist();
}

/* ---------------------------------- init ----------------------------------- */
document.querySelectorAll(".tab").forEach(b => b.addEventListener("click", () => setTab(b.dataset.tab)));
document.getElementById("themeBtn").addEventListener("click", toggleTheme);

(async function init() {
  await loadData();
  applyTheme();
  if (!hasStore) toast("Aviso: armazenamento indisponível — os dados valem só nesta sessão.");
  render();
  setInterval(tickTimer, 1000); tickTimer();
})();
</script>
