<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>ENEM Tracker</title>
<style>
  :root {
    --bg: #f6f7fb; --card: #ffffff; --text: #0f172a; --muted: #64748b;
    --border: #e6e9f2; --soft: #f1f3fa;
    --primary: #6d4aff; --primary-2: #4f46e5; --info: #3b82f6;
    --success: #10b981; --warning: #f59e0b; --danger: #ef4444;
    --ring: rgba(109,74,255,.35);
  }
  body.dark {
    --bg: #0b1020; --card: #131a2e; --text: #e8edf6; --muted: #94a3b8;
    --border: #243049; --soft: #1a2236;
    --primary: #8b78ff; --primary-2: #7c6bff; --info: #60a5fa;
    --success: #34d399; --warning: #fbbf24; --danger: #f87171;
    --ring: rgba(139,120,255,.4);
  }
  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg); color: var(--text);
    -webkit-font-smoothing: antialiased;
    padding-bottom: calc(72px + env(safe-area-inset-bottom));
    transition: background-color .25s ease, color .25s ease;
  }
  .wrap { max-width: 640px; margin: 0 auto; padding: 0 16px; }

  header.top {
    position: sticky; top: 0; z-index: 20;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--border);
    padding: env(safe-area-inset-top) 0 0;
  }
  header.top::after { content: ""; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px;
    background: linear-gradient(90deg, var(--info), var(--primary), var(--success)); opacity: .65; }
  .top-row { display: flex; align-items: center; justify-content: space-between; height: 56px; }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 800; letter-spacing: -.02em; font-size: 18px; }
  .logo { width: 30px; height: 30px; border-radius: 9px; display: grid; place-items: center; color: #fff;
    background: linear-gradient(135deg, var(--info), var(--primary) 55%, var(--success)); font-size: 16px; }
  .icon-btn { width: 40px; height: 40px; border-radius: 11px; border: 1px solid var(--border);
    background: var(--card); color: var(--text); font-size: 18px; display: grid; place-items: center; cursor: pointer; }
  .hdr-timer { background: color-mix(in srgb,var(--primary) 14%,transparent); color: var(--primary);
    border: 1px solid color-mix(in srgb,var(--primary) 30%,var(--border)); border-radius: 999px; padding: 7px 12px;
    font-weight: 800; font-size: 13px; font-variant-numeric: tabular-nums; cursor: pointer; }

  #app { will-change: opacity, transform; }
  #app.fade { animation: fadein .28s ease both; }
  @keyframes fadein { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  h1.page { font-size: 24px; font-weight: 800; letter-spacing: -.02em; margin: 18px 0 2px; }
  p.sub { color: var(--muted); margin: 0 0 16px; font-size: 14px; }

  .grid { display: grid; gap: 12px; }
  .g2 { grid-template-columns: 1fr 1fr; }

  .card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 16px; }
  .card.tight { padding: 14px; }
  .metric .label { color: var(--muted); font-size: 12.5px; margin: 0 0 4px; }
  .metric .value { font-size: 26px; font-weight: 800; letter-spacing: -.02em; }
  .metric .hint { color: var(--muted); font-size: 11.5px; margin-top: 2px; }
  .metric .ico { width: 38px; height: 38px; border-radius: 11px; display: grid; place-items: center; font-size: 18px; flex: 0 0 auto; }

  .row { display: flex; align-items: center; gap: 12px; }
  .between { justify-content: space-between; }

  .section-title { font-size: 16px; font-weight: 700; margin: 22px 0 10px; }

  label.field { display: block; font-size: 13px; font-weight: 600; margin: 0 0 6px; }
  .input, .select, textarea {
    width: 100%; border: 1px solid var(--border); background: var(--card); color: var(--text);
    border-radius: 11px; padding: 11px 12px; font-size: 16px; font-family: inherit; outline: none;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .input:focus, .select:focus, textarea:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--ring); }
  .readonly { background: var(--soft); color: var(--muted); }
  .form-grid { display: grid; gap: 12px; grid-template-columns: 1fr 1fr; }
  .form-grid .full { grid-column: 1 / -1; }

  .btn { appearance: none; border: 1px solid transparent; border-radius: 12px; padding: 12px 16px;
    font-size: 15px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; justify-content: center;
    transition: transform .08s ease, background-color .15s ease; }
  .btn:active { transform: scale(.98); }
  .btn-primary { background: var(--primary); color: #fff; }
  .btn-primary:active { background: var(--primary-2); }
  .btn-ghost { background: var(--card); color: var(--text); border-color: var(--border); }
  .btn-danger { background: var(--card); color: var(--danger); border: 1px solid var(--border); }
  .btn-block { width: 100%; }

  .pill { display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 999px; font-size: 12px; font-weight: 700; }
  .pill-good { background: color-mix(in srgb, var(--success) 16%, transparent); color: var(--success); }
  .pill-warn { background: color-mix(in srgb, var(--warning) 18%, transparent); color: var(--warning); }
  .pill-bad  { background: color-mix(in srgb, var(--danger) 16%, transparent);  color: var(--danger); }
  .pill-muted{ background: var(--soft); color: var(--muted); }
  .pill-info { background: color-mix(in srgb, var(--info) 16%, transparent); color: var(--info); }

  .trend { font-size: 11px; font-weight: 800; padding: 1px 6px; border-radius: 999px; vertical-align: middle; white-space: nowrap; }
  .trend.up { background: color-mix(in srgb, var(--success) 16%, transparent); color: var(--success); }
  .trend.down { background: color-mix(in srgb, var(--danger) 16%, transparent); color: var(--danger); }
  .trend.flat { background: var(--soft); color: var(--muted); }

  .bar { height: 9px; border-radius: 999px; background: var(--soft); overflow: hidden; }
  .bar > span { display: block; height: 100%; border-radius: 999px; background: var(--primary); transition: width .35s ease; }

  .list-item { display: flex; align-items: center; justify-content: space-between; gap: 10px;
    padding: 12px 0; border-bottom: 1px solid var(--border); }
  .list-item:last-child { border-bottom: 0; }
  .li-main { min-width: 0; }
  .li-title { font-weight: 600; font-size: 14.5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .li-meta { color: var(--muted); font-size: 12.5px; margin-top: 2px; }
  .actions { display: flex; align-items: center; gap: 2px; flex: 0 0 auto; }
  .iconbtn { background: none; border: 0; color: var(--muted); font-size: 16px; cursor: pointer;
    width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center; }
  .iconbtn:active { background: var(--soft); }

  .filters { display: flex; gap: 10px; flex-wrap: wrap; }
  .filters .select, .filters .input { flex: 1 1 140px; min-width: 0; }
  .chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .chip { border: 1px solid var(--border); background: var(--card); color: var(--muted);
    border-radius: 999px; padding: 7px 14px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all .12s ease; }
  .chip.active { background: var(--primary); color: #fff; border-color: var(--primary); }

  .dots { display: flex; gap: 6px; justify-content: space-between; }
  .dot { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .dot .d { width: 28px; height: 28px; border-radius: 50%; display: grid; place-items: center; font-size: 12px; font-weight: 700;
    background: var(--soft); color: var(--muted); }
  .dot .d.on { background: var(--success); color: #fff; }
  .dot .d.today { box-shadow: 0 0 0 2px var(--ring); }
  .dot .dl { font-size: 10px; color: var(--muted); }

  .empty { text-align: center; padding: 34px 16px; color: var(--muted); border: 1px dashed var(--border); border-radius: 16px; }
  .empty .big { font-size: 30px; }
  .empty h3 { color: var(--text); margin: 10px 0 4px; font-size: 16px; }

  .chart { display: flex; align-items: flex-end; gap: 8px; height: 150px; padding-top: 8px; }
  .chart .col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; height: 100%; justify-content: flex-end; }
  .chart .stick { width: 70%; max-width: 26px; border-radius: 7px 7px 3px 3px;
    background: linear-gradient(180deg, var(--primary), var(--primary-2)); min-height: 3px; transition: height .3s ease; }
  .chart .clabel { font-size: 10.5px; color: var(--muted); }
  .chart .cval { font-size: 10.5px; color: var(--text); font-weight: 700; }

  .comp-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }
  .comp { text-align: center; }
  .comp .cv { font-weight: 800; font-size: 18px; }
  .comp .ck { color: var(--muted); font-size: 11px; }

  .editing { border-color: color-mix(in srgb, var(--primary) 45%, var(--border)); box-shadow: 0 0 0 3px var(--ring); }
  .edit-flag { background: color-mix(in srgb,var(--primary) 12%,var(--card)); border:1px solid color-mix(in srgb,var(--primary) 30%,var(--border));
    color: var(--primary); font-weight:700; font-size:13px; border-radius:11px; padding:8px 12px; margin-bottom:12px; }

  nav.tabs {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 30;
    background: color-mix(in srgb, var(--card) 92%, transparent);
    backdrop-filter: blur(10px); border-top: 1px solid var(--border);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .tabs-inner { max-width: 640px; margin: 0 auto; display: grid; grid-template-columns: repeat(5, 1fr); }
  .tab { background: none; border: 0; cursor: pointer; color: var(--muted); position: relative;
    padding: 10px 0 8px; display: flex; flex-direction: column; align-items: center; gap: 3px; font-size: 10.5px; font-weight: 600; transition: color .15s ease; }
  .tab .ti { font-size: 20px; line-height: 1; }
  .tab.active { color: var(--primary); }
  .tab.active::before { content: ""; position: absolute; top: 0; width: 26px; height: 3px; border-radius: 0 0 4px 4px; background: var(--primary); }

  .toast { position: fixed; left: 50%; transform: translateX(-50%); bottom: calc(84px + env(safe-area-inset-bottom));
    background: var(--text); color: var(--bg); padding: 10px 16px; border-radius: 999px; font-size: 13px; font-weight: 600;
    z-index: 50; opacity: 0; transition: opacity .2s, transform .2s; pointer-events: none; max-width: 92%; text-align: center;
    display: flex; align-items: center; gap: 6px; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(-4px); pointer-events: auto; }
  .toast button { background: none; border: 0; color: #c4b5fd; font-weight: 800; text-decoration: underline; font-size: 13px; cursor: pointer; padding: 2px 4px; }

  .hidden { display: none !important; }
  .muted { color: var(--muted); }
  .center { text-align: center; }
  .mt8 { margin-top: 8px; } .mt12 { margin-top: 12px; } .mt16 { margin-top: 16px; }
  .danger-zone { border-color: color-mix(in srgb, var(--danger) 30%, var(--border)); }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: .001ms !important; transition-duration: .001ms !important; }
  }
</style>
</head>
<body>
  <header class="top">
    <div class="wrap top-row">
      <div class="brand"><span class="logo">🎓</span> ENEM Tracker</div>
      <div class="row" style="gap:8px">
        <button id="hdrTimer" class="hdr-timer hidden" onclick="setTab('questoes')">⏱ 00:00</button>
        <button class="icon-btn" id="themeBtn" title="Tema">🌙</button>
      </div>
    </div>
  </header>

  <main class="wrap" id="app"></main>

  <nav class="tabs">
    <div class="tabs-inner">
      <button class="tab active" data-tab="painel"><span class="ti">📊</span>Painel</button>
      <button class="tab" data-tab="questoes"><span class="ti">✅</span>Questões</button>
      <button class="tab" data-tab="redacoes"><span class="ti">✍️</span>Redações</button>
      <button class="tab" data-tab="horas"><span class="ti">⏱️</span>Horas</button>
      <button class="tab" data-tab="metas"><span class="ti">🎯</span>Metas</button>
    </div>
  </nav>

  <div class="toast" id="toast"></div>

<script>
"use strict";

/* ----------------------------- dados / domínio ----------------------------- */
const KEY = "enem-tracker:data:v1";

const AREAS = [
  { v: "linguagens", n: "Linguagens" },
  { v: "matematica", n: "Matemática" },
  { v: "natureza", n: "Ciências da Natureza" },
  { v: "humanas", n: "Ciências Humanas" },
];
const SUBJECTS = [
  { v: "matematica", n: "Matemática", a: "matematica" },
  { v: "fisica", n: "Física", a: "natureza" },
  { v: "quimica", n: "Química", a: "natureza" },
  { v: "biologia", n: "Biologia", a: "natureza" },
  { v: "historia", n: "História", a: "humanas" },
  { v: "geografia", n: "Geografia", a: "humanas" },
  { v: "filosofia", n: "Filosofia", a: "humanas" },
  { v: "sociologia", n: "Sociologia", a: "humanas" },
  { v: "portugues", n: "Português", a: "linguagens" },
  { v: "literatura", n: "Literatura", a: "linguagens" },
  { v: "ingles", n: "Inglês", a: "linguagens" },
  { v: "espanhol", n: "Espanhol", a: "linguagens" },
  { v: "artes", n: "Artes", a: "linguagens" },
  { v: "edfisica", n: "Educação Física", a: "linguagens" },
  { v: "tecnologias", n: "Tecnologias", a: "linguagens" },
];
const SUBJ_NAME = Object.fromEntries(SUBJECTS.map(s => [s.v, s.n]));
const DIFFS = [{ v: "facil", n: "Fácil" }, { v: "medio", n: "Médio" }, { v: "dificil", n: "Difícil" }];
const SOURCES = [
  { v: "enem", n: "ENEM antigo" }, { v: "simulado", n: "Simulado" }, { v: "apostila", n: "Apostila" },
  { v: "plataforma", n: "Plataforma" }, { v: "proprias", n: "Questões próprias" },
];
const SOURCE_NAME = Object.fromEntries(SOURCES.map(s => [s.v, s.n]));

/* --------------------------- armazenamento local --------------------------- */
// Funciona em 3 cenários: dentro do Claude (window.storage), em site hospedado
// (localStorage do navegador) e, em último caso, só em memória nesta sessão.
function defaults() { return { entries: [], essays: [], weeklyGoal: 0, weeklyHoursGoal: 0, totalHoursGoal: 0, theme: "light", timer: { running: false, startedAt: null, accumulatedMs: 0 }, backupBase: 0 }; }
let state = defaults();
let editEntryId = null;
let editEssayId = null;
let qf = { subject: "todos", period: "all", q: "" };

const cloudStore = typeof window !== "undefined" && window.storage && typeof window.storage.get === "function";
let localOK = false;
try { if (typeof localStorage !== "undefined") { const k = "__enem_test__"; localStorage.setItem(k, "1"); localStorage.removeItem(k); localOK = true; } } catch (e) { localOK = false; }
const hasStore = cloudStore || localOK;

async function loadData() {
  try {
    if (cloudStore) { const res = await window.storage.get(KEY); if (res && res.value) state = Object.assign(defaults(), JSON.parse(res.value)); }
    else if (localOK) { const v = localStorage.getItem(KEY); if (v) state = Object.assign(defaults(), JSON.parse(v)); }
  } catch (e) {}
}
async function persist() {
  try {
    if (cloudStore) await window.storage.set(KEY, JSON.stringify(state));
    else if (localOK) localStorage.setItem(KEY, JSON.stringify(state));
  } catch (e) {}
}

/* --------------------------------- utils ----------------------------------- */
const uid = () => Math.random().toString(36).slice(2, 10) + Date.now().toString(36);
const todayISO = () => { const d = new Date(); return new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 10); };
function isoDaysAgo(n) { const d = new Date(); d.setDate(d.getDate() - n); return new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 10); }
function fmtBR(iso) { const p = (iso || "").slice(0, 10).split("-"); return p.length === 3 ? `${p[2]}/${p[1]}/${p[0]}` : iso; }
function fmtMin(m) { m = +m || 0; if (m <= 0) return "0min"; const h = Math.floor(m / 60), r = m % 60; return h ? (r ? `${h}h${String(r).padStart(2,"0")}` : `${h}h`) : `${r}min`; }
const esc = (s) => String(s == null ? "" : s).replace(/[&<>"]/g, c => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
const attr = (s) => esc(s).replace(/'/g, "&#39;");
const taxa = (c, t) => t > 0 ? Math.round((c / t) * 1000) / 10 : 0;
function rateClass(t) { return t >= 70 ? "pill-good" : t >= 50 ? "pill-warn" : "pill-bad"; }

function startOfWeekISO() {
  const d = new Date(); const day = (d.getDay() + 6) % 7;
  d.setDate(d.getDate() - day); d.setHours(0,0,0,0);
  return new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 10);
}
function prevWeekRange() {
  const s = startOfWeekISO(); const base = new Date(s + "T00:00:00");
  const end = new Date(base); end.setDate(end.getDate() - 1);
  const start = new Date(base); start.setDate(start.getDate() - 7);
  const iso = x => new Date(x.getTime() - x.getTimezoneOffset() * 60000).toISOString().slice(0, 10);
  return { start: iso(start), end: iso(end) };
}
const isThisWeek = (iso) => (iso || "").slice(0,10) >= startOfWeekISO();
const isToday = (iso) => (iso || "").slice(0,10) === todayISO();
function isThisMonth(iso) { return (iso || "").slice(0,7) === todayISO().slice(0,7); }

function streak(entries) {
  if (!entries.length) return 0;
  const days = new Set(entries.map(e => e.date.slice(0,10)));
  let s = 0; const d = new Date();
  const k = x => new Date(x.getTime() - x.getTimezoneOffset()*60000).toISOString().slice(0,10);
  if (!days.has(k(d))) { d.setDate(d.getDate()-1); if (!days.has(k(d))) return 0; }
  while (days.has(k(d))) { s++; d.setDate(d.getDate()-1); }
  return s;
}
function bySubject(entries) {
  const m = {};
  entries.forEach(e => { const x = m[e.subject] || (m[e.subject] = { total:0, correct:0 }); x.total += +e.total; x.correct += +e.correct; });
  return Object.keys(m).map(k => ({ subject:k, name: SUBJ_NAME[k]||k, total:m[k].total, correct:m[k].correct, taxa: taxa(m[k].correct, m[k].total) }))
    .sort((a,b)=> b.taxa - a.taxa);
}
function timeBySubject(entries) {
  const m = {};
  entries.forEach(e => { m[e.subject] = (m[e.subject]||0) + (+e.minutes||0); });
  return Object.keys(m).filter(k=>m[k]>0).map(k=>({ subject:k, name:SUBJ_NAME[k]||k, min:m[k] })).sort((a,b)=>b.min-a.min);
}
function last7(entries) {
  const out = [];
  for (let i=6;i>=0;i--){ const d=new Date(); d.setDate(d.getDate()-i);
    const key=new Date(d.getTime()-d.getTimezoneOffset()*60000).toISOString().slice(0,10);
    const tot=entries.filter(e=>e.date.slice(0,10)===key).reduce((s,e)=>s+(+e.total),0);
    out.push({ label: `${String(d.getDate()).padStart(2,"0")}/${String(d.getMonth()+1).padStart(2,"0")}`, total: tot }); }
  return out;
}
function trendChip(cur, prev) {
  if (!(prev > 0)) return "";
  const diff = cur - prev;
  if (diff === 0) return `<span class="trend flat">0%</span>`;
  const pct = Math.round(Math.abs(diff) / prev * 100);
  return `<span class="trend ${diff>0?'up':'down'}">${diff>0?'▲':'▼'} ${pct}%</span>`;
}

/* --------------------------------- toast ----------------------------------- */
let toastTimer;
function toast(msg, actionLabel, actionFn) {
  const el = document.getElementById("toast");
  el.innerHTML = `<span>${esc(msg)}</span>` + (actionLabel ? `<button id="toastAct">${esc(actionLabel)}</button>` : "");
  el.classList.add("show");
  if (actionLabel && actionFn) {
    const b = document.getElementById("toastAct");
    if (b) b.onclick = () => { el.classList.remove("show"); clearTimeout(toastTimer); actionFn(); };
  }
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove("show"), actionLabel ? 6000 : 2400);
}

/* -------------------------------- cronômetro ------------------------------- */
function fmtClock(ms){ const s=Math.max(0,Math.floor(ms/1000)); const h=Math.floor(s/3600), m=Math.floor((s%3600)/60), sec=s%60;
  const mm=String(m).padStart(2,"0"), ss=String(sec).padStart(2,"0"); return h>0 ? `${h}:${mm}:${ss}` : `${mm}:${ss}`; }
function timerElapsedMs(){ const t=state.timer||{}; return (t.accumulatedMs||0) + (t.running && t.startedAt ? Date.now()-t.startedAt : 0); }
function timerCardHtml(){
  const ms=timerElapsedMs(); const running=!!(state.timer&&state.timer.running); const has=ms>=1000;
  return `<div class="row between">
      <div><div class="li-meta" style="margin:0">Cronômetro de estudo</div>
        <div id="timerDisplay" style="font-size:30px;font-weight:800;letter-spacing:-.02em;font-variant-numeric:tabular-nums">${fmtClock(ms)}</div></div>
      <div>${running
        ? `<button class="btn btn-ghost" onclick="timerPause()">⏸ Pausar</button>`
        : `<button class="btn btn-primary" onclick="timerStart()">▶ ${has?'Continuar':'Iniciar'}</button>`}</div>
    </div>
    <div class="row mt12" style="gap:8px">
      <button class="btn btn-ghost" style="flex:1" onclick="timerUse()">Usar no campo Tempo</button>
      <button class="btn btn-ghost" style="flex:1" onclick="timerReset()">Zerar</button>
    </div>
