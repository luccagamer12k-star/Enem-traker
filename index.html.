      <div class="row" style="gap:8px;align-items:flex-start"><span style="font-size:18px">🎯</span>
      <div><b>Sugestão</b><p style="margin:4px 0 0;font-size:14px;line-height:1.5">${suggestion}</p></div></div>
    </div>`;
}

