      </div>
    </div>

    <div class="section-title">Questões nos últimos 7 dias</div>
    <div class="card">
      <div class="chart">
        ${seven.map(d=>`<div class="col"><div class="cval">${d.total||""}</div>
          <div class="stick" style="height:${d.total? Math.max(4, Math.round(d.total/max*100)) : 1}%"></div>
          <div class="clabel">${d.label}</div></div>`).join("")}
      </div>
