  }
  const qToday = e.filter(x=>isToday(x.date)).reduce((s,x)=>s+(+x.total),0);
  const week = e.filter(x=>isThisWeek(x.date));
  const qWeek = week.reduce((s,x)=>s+(+x.total),0);
  const lw = prevWeekRange();
  const qLastWeek = e.filter(x=> x.date.slice(0,10)>=lw.start && x.date.slice(0,10)<=lw.end).reduce((s,x)=>s+(+x.total),0);
  const totalC = e.reduce((s,x)=>s+(+x.correct),0), totalT = e.reduce((s,x)=>s+(+x.total),0);
  const overall = taxa(totalC, totalT);
  const minWeek = week.reduce((s,x)=>s+(+x.minutes||0),0);
  const st = streak(e);
  const monthEssays = state.essays.filter(x=>isThisMonth(x.date)).length;

  const tmap = {}; e.forEach(x=>{ tmap[x.subject]=(tmap[x.subject]||0)+(+x.minutes||0); });
