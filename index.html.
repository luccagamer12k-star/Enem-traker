  return `<h1 class="page">Painel</h1><p class="sub">Sua evolução de estudos em um só lugar.</p>
    <div class="grid g2">
      ${metricCard("Questões hoje", qToday, "✅", "color-mix(in srgb,var(--primary) 14%,transparent)", "var(--primary)")}
      ${metricCard("Na semana", qWeek, "🗓️", "color-mix(in srgb,var(--info) 14%,transparent)", "var(--info)", "vs. semana passada", trendChip(qWeek, qLastWeek))}
      ${metricCard("Taxa de acerto", overall + "%", "🎯", "color-mix(in srgb,var(--success) 14%,transparent)", "var(--success)")}
      ${metricCard("Sequência", st + (st===1?" dia":" dias"), "🔥", "color-mix(in srgb,var(--warning) 16%,transparent)", "var(--warning)", "estudando sem parar")}
      ${metricCard("Tempo (semana)", fmtMin(minWeek), "⏱️", "color-mix(in srgb,var(--warning) 16%,transparent)", "var(--warning)")}
