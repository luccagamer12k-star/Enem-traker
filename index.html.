    <div class="card">
      ${subs.slice(0,8).map(s=>`<div style="margin:10px 0">
        <div class="row between" style="margin-bottom:6px"><span style="font-weight:600;font-size:14px">${s.name}</span>
        <span class="pill ${rateClass(s.taxa)}">${s.taxa}%</span></div>
        <div class="bar"><span style="width:${s.taxa}%;background:${s.taxa>=70?'var(--success)':s.taxa>=50?'var(--warning)':'var(--danger)'}"></span></div>
        <div class="li-meta" style="margin-top:4px">${s.correct}/${s.total} questões · ${fmtMin(tmap[s.subject]||0)}</div>
      </div>`).join("")}
    </div>` : ""}

    <div class="section-title">Diagnóstico</div>
    <div class="card">
      <div class="list-item"><span class="muted">Melhor matéria</span><span class="pill pill-good">${best? best.name+" · "+best.taxa+"%" : "—"}</span></div>
